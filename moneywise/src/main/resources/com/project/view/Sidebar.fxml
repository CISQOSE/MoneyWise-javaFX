<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.controller.SidebarController"
      fx:id="sidebarRoot"
      styleClass="sidebar"
      stylesheets="@../style/global.css, @../style/sidebar.css"
      prefWidth="240" minWidth="240" maxWidth="240">

    <VBox styleClass="sidebar-logo-zone" spacing="2">
        <Label text="Money Wise" styleClass="sidebar-logo-title"/>
        <Label text="Votre finances. Votre contrôle." styleClass="sidebar-logo-sub"/>
    </VBox>

    <VBox VBox.vgrow="ALWAYS" spacing="0" style="-fx-padding: 8 0;">
        <Label text="MENU" styleClass="sidebar-section-label"/>
        
        <HBox fx:id="navHome" styleClass="nav-item" onMouseClicked="#goToHome">
            <Label fx:id="navHomeIcon" styleClass="nav-item-icon"/>
            <Label text="Dashboard" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox fx:id="navTransaction" styleClass="nav-item" onMouseClicked="#goToTransaction">
            <Label fx:id="navTransactionIcon" styleClass="nav-item-icon"/>
            <Label text="Transactions" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox fx:id="navStatistique" styleClass="nav-item" onMouseClicked="#goToStatistique">
            <Label fx:id="navStatistiqueIcon" styleClass="nav-item-icon"/>
            <Label text="Statistiques" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
        </HBox>

        <Label fx:id="adminSectionLabel" text="ADMINISTRATION" styleClass="sidebar-section-label" visible="false" managed="false"/>

        <HBox fx:id="navAdminUtilisateurs" styleClass="nav-item" onMouseClicked="#goToAdminUtilisateurs" visible="false" managed="false">
            <Label fx:id="navAdminUtilisateursIcon" styleClass="nav-item-icon"/>
            <Label text="Utilisateurs" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox fx:id="navAdminCategories" styleClass="nav-item" onMouseClicked="#goToAdminCategories" visible="false" managed="false">
            <Label fx:id="navAdminCategoriesIcon" styleClass="nav-item-icon"/>
            <Label text="Catégories" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox fx:id="navAdminLogs" styleClass="nav-item" onMouseClicked="#goToAdminLogs" visible="false" managed="false">
            <Label fx:id="navAdminLogsIcon" styleClass="nav-item-icon"/>
            <Label text="Journal" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox fx:id="navAdminTransactions" styleClass="nav-item" onMouseClicked="#goToAdminTransactions" visible="false" managed="false">
            <Label fx:id="navAdminTransactionsIcon" styleClass="nav-item-icon"/>
            <Label text="Toutes transac." styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox fx:id="navAdminStatistiques" styleClass="nav-item" onMouseClicked="#goToAdminStatistiques" visible="false" managed="false">
            <Label fx:id="navAdminStatistiquesIcon" styleClass="nav-item-icon"/>
            <Label text="Toutes stat." styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
        </HBox>

        <Label text="COMPTE" styleClass="sidebar-section-label"/>

        <HBox fx:id="navProfil" styleClass="nav-item" onMouseClicked="#goToProfil">
            <Label fx:id="navProfilIcon" styleClass="nav-item-icon"/>
            <Label text="Mon profil" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
        </HBox>

        <HBox fx:id="navAlertes" styleClass="nav-item" onMouseClicked="#goToAlertes">
            <Label fx:id="navAlertesIcon" styleClass="nav-item-icon"/>
            <Label text="Alertes" styleClass="nav-item-label" HBox.hgrow="ALWAYS"/>
            <Label fx:id="alerteBadge" text="0" styleClass="nav-badge" visible="false" managed="false"/>
        </HBox>
    </VBox>

    <HBox styleClass="sidebar-user-zone" spacing="10" alignment="CENTER_LEFT">
        <StackPane styleClass="sidebar-user-avatar">
            <Label fx:id="avatarLabel" text="?" styleClass="sidebar-user-avatar-label"/>
        </StackPane>
        <Button text="⏻ Déconnexion" styleClass="btn-logout" onAction="#handleLogout"/>
    </HBox>
</VBox>